DATABASE_HOST=localhost
POSTGRES_DB=rento
POSTGRES_USER=rento
POSTGRES_PASSWORD=yourpassword

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SMTP (Mailpit for local dev)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=rento@localhost
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# Agent configuration
AGENT2_TOP_N_MATCHES=20
AGENT3_MAX_NEGOTIATION_ROUNDS=5
AGENT3_REPLY_POLL_INTERVAL_SECONDS=1800

# CORS — comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Debug mode — enables dev-only endpoints (e.g. /agents/dev/*).
DEBUG=true

# JWT — change this to a long random secret in any real deployment
JWT_SECRET=put-your-JWT-secret-here
JWT_EXPIRE_HOURS=168
