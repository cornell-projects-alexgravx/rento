DATABASE_URL=postgresql+asyncpg://rento:rento@localhost:5432/rento
POSTGRES_DB=rento
POSTGRES_USER=rento
POSTGRES_PASSWORD=yourpasswordhere

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SMTP (Mailhog for local dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=rento@localhost
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# Agent configuration
AGENT3_MAX_NEGOTIATION_ROUNDS=5
AGENT3_REPLY_POLL_INTERVAL_SECONDS=1800
AGENT2_TOP_N_MATCHES=20

# CORS — comma-separated list of allowed origins.
# Default is http://localhost:3000 when this var is unset.
CORS_ORIGINS=http://localhost:3000

# Debug mode — enables dev-only endpoints (e.g. /agents/dev/*).
# Must be "true" (case-insensitive). Never set to true in production.
DEBUG=false
